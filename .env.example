# --- LLM backend (aicore-proxy on NAS) ---
# Anthropic-compatible base URL. Default: https://aicore.superdyland.uk
AICORE_BASE_URL=https://aicore.superdyland.uk
# API token issued by aicore-proxy. Sent as the anthropic x-api-key header.
AICORE_TOKEN=

# Model id exposed by aicore-proxy. Default: my-claude-opus
AICORE_MODEL=my-claude-opus

# --- Server ---
PORT=8787
HOST=0.0.0.0

# --- Auth (HTTP Basic Auth for the chat UI + API, except /health) ---
# If either is empty the server runs unauthenticated (loud warning at startup).
# The tunnel exposes this service publicly, so DO NOT leave this empty in prod.
AUTH_USER=
AUTH_PASS=

# --- Skill roots (colon-separated). Default: ./skills ---
SKILLS_PATH=./skills

# --- Per-skill env passthrough (only what skills need) ---
# send-email
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# vault-lookup
VAULTWARDEN_URL=
VAULTWARDEN_TOKEN=

# nas-calendar
CALDAV_URL=
CALDAV_USER=
CALDAV_PASS=

# zspace-nas
ZSPACE_URL=
ZSPACE_TOKEN=
