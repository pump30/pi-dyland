# --- LLM backend (aicore-proxy on NAS) ---
# Anthropic-compatible base URL. Default: https://aicore.superdyland.uk
AICORE_BASE_URL=https://aicore.superdyland.uk
# API token issued by aicore-proxy. Sent as the anthropic x-api-key header.
AICORE_TOKEN=

# Model id exposed by aicore-proxy. Default: my-claude-opus
AICORE_MODEL=my-claude-opus

# --- Server ---
PORT=8787
HOST=0.0.0.0

# --- Auth (HTTP Basic Auth for the chat UI + API, except /health) ---
# If either is empty the server runs unauthenticated (loud warning at startup).
# The tunnel exposes this service publicly, so DO NOT leave this empty in prod.
AUTH_USER=
AUTH_PASS=

# --- Skill roots (colon-separated). Default: ./skills ---
SKILLS_PATH=./skills

# Optional: colon-separated roots to look for Claude Code SKILL.md files
# (e.g. ~/.claude/skills). Matched by pi skill name (snake ↔ kebab).
# If found, the SKILL.md `description` is APPENDED to the pi skill's
# description to help the LLM pick the right tool. Never used to execute
# Claude Code scripts.
CLAUDE_SKILLS_PATH=

# --- Per-skill env passthrough (only what skills need) ---
# send-email
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# vault-lookup
VAULTWARDEN_URL=
VAULTWARDEN_TOKEN=

# nas-calendar
# Radicale principal URL (WITH trailing slash), NOT a single calendar URL.
# The skill discovers all calendars under this principal via PROPFIND.
# On NAS with --network host: http://127.0.0.1:5232/<user>/
# e.g. http://127.0.0.1:5232/1069235479@qq.com/
CALDAV_URL=
CALDAV_USER=
CALDAV_PASS=

# web-search (Tavily). Free tier: 1000 searches/month.
# Get a key at https://tavily.com (sign up with email).
TAVILY_API_KEY=

# --- Long-term memory (Phase D) ---
# Directory for durable JSON state (user profile + preferences + thread meta).
# On NAS: /data (bind-mounted from /tmp/zfsv3/sata11/15869560895/data/pi-dyland-data)
# Local dev: leave empty to default to ./data
DATA_DIR=
